{
  "manifest_version": 3,
  "name": "Links Research Capture",
  "version": "1.0.0",
  "description": "Capture web content into your Links research pots",
  "permissions": ["contextMenus", "storage", "activeTab", "scripting", "pageCapture"],
  "host_permissions": ["http://127.0.0.1/*"],
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/index.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/index.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
