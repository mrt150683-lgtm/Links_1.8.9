{
  "name": "links-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @links/api dev",
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:migrate": "node --loader ts-node/esm scripts/migrate.ts",
    "db:reset": "node --loader ts-node/esm scripts/db-reset.ts",
    "worker": "pnpm --filter @links/worker dev",
    "launcher": "pnpm --filter @links/launcher dev",
    "launcher:exe": "pnpm --filter @links/launcher build:exe",
    "launcher:installer": "pnpm --filter @links/launcher build:installer"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0"
  }
}
