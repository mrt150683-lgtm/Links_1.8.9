############################################
# OS / Editor noise
############################################
.DS_Store
Thumbs.db
Desktop.ini

*.swp
*.swo
*.tmp
*.bak
*.old

.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.iml

############################################
# Node / TS
############################################
node_modules/
.pnpm-store/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

dist/
build/
out/
lib/
.eslintcache
*.tsbuildinfo

coverage/
.nyc_output/

############################################
# Monorepo / build caches
############################################
.turbo/
.nx/
.cache/
.parcel-cache/
.next/
.svelte-kit/
.vite/
.vitest/
.rollup.cache/

############################################
# Env / secrets (keep .env.example)
############################################
.env
.env.*
!.env.example

# Generic secret/key material
secrets/
secret/
private/
keys/
keyring/
*.key
*.pem
*.p12
*.pfx
*.der
*.crt
*.cer
*.csr
*.jks
*.kdbx
*.asc
*.gpg
*.pgp
*.age
*.sops
*.enc
*.encrypted
*.vault

# If you generate local auth tokens / key files
**/token*
**/*token*
**/auth*.json
**/key*.json

############################################
# Databases (local-first means: do NOT commit)
############################################
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal
*.sqlite-shm
*.sqlite-wal

# Typical local data dirs (adjust to your actual paths)
data/
Data/
storage/
Storage/
var/
tmp/
temp/

############################################
# Exports / imports / bundles (sensitive)
############################################
exports/
export/
imports/
import/
bundles/
bundle/
*.zip
*.tar
*.tgz
*.gz
*.7z
*.rar
*.lynxpot
*.links-pot

############################################
# Uploaded assets / binaries (no doc uploads, no exe uploads)
############################################
# Executables / installers
*.exe
*.dll
*.msi
*.cab
*.bat
*.cmd
*.ps1
*.app
*.dmg
*.pkg
*.deb
*.rpm
*.apk
*.ipa

# Documents (binary office formats + PDFs)
*.pdf
*.doc
*.docx
*.odt
*.rtf
*.xls
*.xlsx
*.ods
*.ppt
*.pptx
*.odp

# Optional: if you also want to block generic binary blobs
*.bin
*.blob

############################################
# Logs
############################################
logs/
*.log

############################################
# Docker / runtime
############################################
*.pid
*.pid.lock
